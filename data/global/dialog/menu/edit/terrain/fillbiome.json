{
	"type": "multi_action",
	"title": {
		"text": "Fillbiome",
		"color": "dark_green"
	},
	"body": {
		"type": "item",
		"item": {
			"id": "map"
		}
	},
	"inputs": [
		{
			"type": "text",
			"key": "biome",
			"label": {
				"text": "Biome",
				"color": "green"
			},
			"initial": "\"example:my_custom_biome\"",
			"max_length": 100
		},
		{
			"type": "text",
			"key": "replace",
			"label": {
				"text": "Replace",
				"color": "light_purple"
			},
			"initial": "\"minecaft:the_void\"",
			"max_length": 100
		}
	],
	"can_close_with_escape": true,
	"pause": false,
	"columns": 2,
	"actions": [
		{"label": {"text": "Confirm", "color": "green", "bold": true}, "action": {"type": "dynamic/run_command", "template": "function config:events/edit/terrain/fillbiome {biome: \"$(biome)\", replace: \"$(replace)\"}"}},

		{"label": {"text": 		     "Back to ", "extra": [{"text": "terrain ", "color": "#5DBB63", "italic":   true}, "menu"]}, "action": {"type": "show_dialog", "dialog": "global:menu/edit/terrain"}},
		{"label": {"text": 		     "Back to ", "extra": [{"text":    "edit ", "color":    "gold", "italic":   true}, "menu"]}, "action": {"type": "show_dialog", "dialog": 		 "global:menu/edit"}},
		{"label": {"text": 		     "Back to ", "extra": [{"text":     "menu", "color":    "gold", "italic": true}]}, 		     "action": {"type": "show_dialog", "dialog": 		 	  "global:menu"}},
		{"label": {"text": "Back to main menu"}, 																				 "action": {"type": "show_dialog", "dialog":            "global:config"}}
	]
}
