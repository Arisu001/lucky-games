		{"type": "single_option", "key":   "survive_warden__rankings", "label": {"text":   "Survive Warden", "extra": [{"text": ": ", "color": "yellow"}], "color": "#0D7377", "bold": true}, "options": [{"id": "top_3", "display": {"text": "Top 3", "color": "gold", "italic": true}, "initial":  true}, {"id": "top_5", "display": {"text": "Top 5", "color": "blue", "italic": true}, "initial": false}, {"id": "top_10", "display": {"text": "Top 10", "color": "green", "italic": true}, "initial": false}]},
		{"type": "single_option", "key":          "thimble__rankings", "label": {"text":          "Thimble", "extra": [{"text": ": ", "color": "yellow"}], "color": "#DA70D6", "bold": true}, "options": [{"id": "top_3", "display": {"text": "Top 3", "color": "gold", "italic": true}, "initial":  true}, {"id": "top_5", "display": {"text": "Top 5", "color": "blue", "italic": true}, "initial": false}, {"id": "top_10", "display": {"text": "Top 10", "color": "green", "italic": true}, "initial": false}]},
		{"type": "single_option", "key": "trident_shooting__rankings", "label": {"text": "Trident Shooting", "extra": [{"text": ": ", "color": "yellow"}], "color": "#6A0DAD", "bold": true}, "options": [{"id": "top_3", "display": {"text": "Top 3", "color": "gold", "italic": true}, "initial": false}, {"id": "top_5", "display": {"text": "Top 5", "color": "blue", "italic": true}, "initial": false}, {"id": "top_10", "display": {"text": "Top 10", "color": "green", "italic": true}, "initial":  true}]}
	
