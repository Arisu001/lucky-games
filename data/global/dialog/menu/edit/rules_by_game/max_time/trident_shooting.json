{
	"type": "multi_action",
	"title": {
		"text": "Trident Shooting",
		"color": "#6A0DAD",
		"extra": [
			{
				"text": ": ",
				"color": "yellow"
			},
			{
				"text": "Max Time",
				"color": "#EF4444"
			}
		]
	},
	"body": {
		"type": "item",
		"item": {
			"id": "clock"
		}
	},
	"inputs": [
		{"type": "number_range", "key":    "trident_shooting__hour", "label":         "Hour", "start": 0, "end": 59, "step": 1, "initial":  1},
		{"type": "number_range", "key":  "trident_shooting__minute", "label":       "Minute", "start": 0, "end": 59, "step": 1, "initial": 30},
		{"type": "number_range", "key": "trident_shooting__seconde", "label":      "Seconde", "start": 0, "end": 59, "step": 1, "initial":  0},
		{"type": "number_range", "key":    "trident_shooting__tick", "label": "Milliseconde", "start": 0, "end": 20, "step": 1, "initial":  0}
	],
	"can_close_with_escape": true,
	"pause": false,
	"columns": 4,
	"actions": [
		{"label": {"text": "Confirm", "color": "green", "bold": true}, "action": {"type": "dynamic/run_command", "template": "function config:events/edit/rules/set_time/trident_shooting {trident_shooting__hour: \"$(trident_shooting__hour)\", trident_shooting__minute: \"$(trident_shooting__minute)\", trident_shooting__seconde: \"$(trident_shooting__seconde)\", trident_shooting__tick: \"$(trident_shooting__tick)\", global__hour: \"$(global__hour)\", global__minute: \"$(global__minute)\", global__seconde: \"$(global__seconde)\", global__tick: \"$(global__tick)\"}"}},

		{"label": {"text": 	         "Back to ", "extra": [{"text":      "max time ", "color": "#EF4444", "italic": true}, "menu"]}, "action": {"type": "show_dialog", "dialog": "global:menu/edit/rules_by_game/max_time"}},
		{"label": {"text": 	         "Back to ", "extra": [{"text": "rules by game ", "color":  "yellow", "italic": true}, "menu"]}, "action": {"type": "show_dialog", "dialog":          "global:menu/edit/rules_by_game"}},
		{"label": {"text": 	         "Back to ", "extra": [{"text":          "edit ", "color":    "gold", "italic": true}, "menu"]}, "action": {"type": "show_dialog", "dialog":                        "global:menu/edit"}},
		{"label": {"text": 		     "Back to ", "extra": [{"text":           "menu", "color":    "gold", "italic": true}]}, 		 "action": {"type": "show_dialog", "dialog":                             "global:menu"}},
		{"label": {"text": "Back to main menu"}, 																				     "action": {"type": "show_dialog", "dialog":                           "global:config"}}
	]
}
