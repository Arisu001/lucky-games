{
	"type": "multi_action",
	"title": {
		"text": "Respawnable",
		"color": "#10B981"
	},
	"body": {
		"type": "item",
		"item": {
			"id": "ender_eye"
		}
	},
	"inputs": [
		{
			"type": "boolean", 
			"key": "global__respawnable", 
			"label": {
				"text": "Respawn All", 
				"color": "#059669", 
				"bold": true
			}, 
			"initial": false, 
			"on_true": "enabled", 
			"on_false": "disabled"
		}
	
	],
	"can_close_with_escape": true,
	"pause": true,
	"after_action": "close",
	"columns": 3,
	"actions": [
		{"label": {"text": "Confirm", "color": "green", "bold": true}, "action": {"type": "dynamic/run_command", "template": "function config:events/edit/rules/respawnable {global: \"$(global__respawnable)\", boat_race: \"$(boat_race__respawnable)\", burn_survival: \"$(burn_survival__respawnable)\", golf: \"$(golf__respawnable)\", jump_league: \"$(jump_league__respawnable)\", spleef: \"$(spleef__respawnable)\", survive_warden: \"$(survive_warden__respawnable)\", thimble: \"$(thimble__respawnable)\", trident_shooting: \"$(trident_shooting__respawnable)\"}"}},

		{"label": {"text": 	         "Back to ", "extra": [{"text": "global rules ", "color": "gray", "italic": true}, "menu"]}, "action": {"type": "show_dialog", "dialog": "global:menu/edit/global_rules"}},
		{"label": {"text": 	         "Back to ", "extra": [{"text":         "edit ", "color": "gold", "italic": true}, "menu"]}, "action": {"type": "show_dialog", "dialog":              "global:menu/edit"}},
		{"label": {"text": 		     "Back to ", "extra": [{"text":          "menu", "color": "gold", "italic": true}]}, 		 "action": {"type": "show_dialog", "dialog":                   "global:menu"}},
		{"label": {"text": "Back to main menu"}, 																				 "action": {"type": "show_dialog", "dialog":                 "global:config"}}
	]
}
