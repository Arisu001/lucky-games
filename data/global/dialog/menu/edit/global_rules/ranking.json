{
	"type": "multi_action",
	"title": {
		"text": "Ranking",
		"color": "#FFD700"
	},
	"body": {
		"type": "item",
		"item": {
			"id": "nether_star"
		}
	},
	"inputs": [
		{
			"type": "single_option",
			"key": "global__rankings",
			"label": {
				"text": "Choose your rankings",
				"bold": true
			},
			"options": [
				{"id":  "top_3", "display": {"text":  "Top 3", "color":  "gold", "italic": true}, "initial": false},
				{"id":  "top_5", "display": {"text":  "Top 5", "color":  "blue", "italic": true}, "initial": false},
				{"id": "top_10", "display": {"text": "Top 10", "color": "green", "italic": true}, "initial": false}
			]
		}
	],
	"can_close_with_escape": true,
	"pause": true,
	"after_action": "close",
	"columns": 3,
	"actions": [
		{"label": {"text": "Confirm", "color": "green", "bold": true}, "action": {"type": "dynamic/run_command", "template": "function config:events/edit/rules/rankings {global: \"$(global__rankings)\", boat_race: \"$(boat_race__rankings)\", burn_survival: \"$(burn_survival__rankings)\", golf: \"$(golf__rankings)\", jump_league: \"$(jump_league__rankings)\", spleef: \"$(spleef__rankings)\", survive_warden: \"$(survive_warden__rankings)\", thimble: \"$(thimble__rankings)\", trident_shooting: \"$(trident_shooting__rankings)\"}"}},

		{"label": {"text": 	         "Back to ", "extra": [{"text": "global rules ", "color": "gray", "italic": true}, "menu"]}, "action": {"type": "show_dialog", "dialog": "global:menu/edit/global_rules"}},
		{"label": {"text": 	         "Back to ", "extra": [{"text":         "edit ", "color": "gold", "italic": true}, "menu"]}, "action": {"type": "show_dialog", "dialog":              "global:menu/edit"}},
		{"label": {"text": 		     "Back to ", "extra": [{"text":          "menu", "color": "gold", "italic": true}]}, 		 "action": {"type": "show_dialog", "dialog":                   "global:menu"}},
		{"label": {"text": "Back to main menu"}, 																				 "action": {"type": "show_dialog", "dialog":                 "global:config"}}
	]
}
